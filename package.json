{
  "name": "chaoxing-sign",
  "version": "4.3.5",
  "description": "超星学习通签到项目",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev:serve dev --filter=./apps/*",
    "build": "corepack pnpm@10.11.0 --filter server build && corepack pnpm@10.11.0 --filter web build",
    "start": "node ./apps/server/build/index.js",
    "serve": "node ./apps/server/build/serve.js",
    "monitor": "node ./apps/server/build/monitor.js",
    "lint": "turbo run lint",
    "desktop:start": "corepack pnpm@10.11.0 --filter chaoxing-sign-desktop start",
    "desktop:package": "corepack pnpm@10.11.0 --filter chaoxing-sign-desktop package",
    "desktop:make": "corepack pnpm@10.11.0 --filter chaoxing-sign-desktop make",
    "desktop:assets": "corepack pnpm@10.11.0 --filter chaoxing-sign-desktop assets",
    "desktop:make:mac": "corepack pnpm@10.11.0 --filter chaoxing-sign-desktop make:mac",
    "desktop:make:win": "corepack pnpm@10.11.0 --filter chaoxing-sign-desktop make:win"
  },
  "repository": "https://github.com/cxOrz/chaoxing-sign-cli.git",
  "author": "mcx",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "turbo": "^1.8.8"
  }
}
