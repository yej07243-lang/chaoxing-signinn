{
  "name": "chaoxing-sign-desktop",
  "productName": "Chaoxing Sign Desktop",
  "version": "1.0.0",
  "description": "Electron desktop shell with a dedicated React + Vite frontend",
  "main": "electron/main/index.js",
  "author": "a1050",
  "license": "MIT",
  "scripts": {
    "dev:ui": "vite --config vite.config.ts",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron-forge start",
    "start": "concurrently -k \"pnpm dev:ui\" \"pnpm dev:electron\"",
    "assets": "python3 scripts/generate_packaging_assets.py || py -3 scripts/generate_packaging_assets.py",
    "build:ui": "vite build --config vite.config.ts",
    "package": "pnpm build:ui && electron-forge package",
    "make": "pnpm build:ui && electron-forge make",
    "make:mac": "pnpm build:ui && electron-forge make --platform darwin --arch arm64",
    "make:win": "pnpm build:ui && electron-forge make --platform win32 --arch x64"
  },
  "config": {
    "forge": "./forge.config.js"
  },
  "dependencies": {},
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-dmg": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^35.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "wait-on": "^8.0.1"
  }
}
